{
  "name": "frontend-switch-os",
  "version": "2.0.0",
  "private": true,
  "description": "Full-stack senior frontend interview preparation tracker.",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm run dev --workspace client",
    "dev:api": "npm run dev --workspace server",
    "build": "npm run build --workspace client",
    "check": "npm run check --workspace client && npm run check --workspace server",
    "check:docs": "node scripts/check-docs.js",
    "enrich:leetcode": "node scripts/enrich-leetcode-links.js",
    "lint:commits": "node scripts/lint-commits.js",
    "seed": "npm run seed --workspace server"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1"
  }
}
